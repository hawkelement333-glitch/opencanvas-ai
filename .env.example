# OpenCanvas AI local configuration template.
#
# This file contains placeholders and non-secret development defaults only.
# Copy it to .env; never put real credentials in .env.example or commit .env.
# No external credential is required for local mock mode.

# Shared settings (optional for local development; defaults shown)
OPENCANVAS_ENVIRONMENT=development
# Optional. Leave false in normal operation; `pnpm demo` sets a guarded isolated configuration.
OPENCANVAS_DEMO_MODE=false
OPENCANVAS_LOG_LEVEL=INFO
OPENCANVAS_API_PREFIX=/api/v1

# Persistence and browser access
# Required for the PostgreSQL development stack. The credential below is a local-only
# placeholder used by docker-compose.yml; replace it in every non-local deployment.
OPENCANVAS_DATABASE_URL=postgresql+asyncpg://opencanvas:opencanvas@localhost:5432/opencanvas
# Optional locally. In production, set an explicit allowlist; do not use wildcard origins.
OPENCANVAS_CORS_ORIGINS=["http://localhost:3000"]

# AI generation
# `auto` uses OpenAI only when OPENAI_API_KEY is set; otherwise it uses deterministic mock AI.
# Set `mock` explicitly when source content must never leave the local environment.
OPENCANVAS_AI_PROVIDER=auto
# Optional and server-only. Never prefix secrets with NEXT_PUBLIC_. Leave empty for mock AI.
# Live AI sends the user instruction and selected context to the configured OpenAI service.
OPENAI_API_KEY=
# Optional model/runtime tuning (defaults shown)
OPENCANVAS_OPENAI_MODEL=gpt-5.6-terra
OPENCANVAS_OPENAI_TIMEOUT_SECONDS=45
OPENCANVAS_AI_CONTEXT_CHARACTER_LIMIT=60000

# Document ingestion and retrieval (optional tuning; defaults shown).
# Keep storage outside apps/web/public and every other served or executable directory.
OPENCANVAS_DOCUMENT_STORAGE_ROOT=./data/documents
OPENCANVAS_DOCUMENT_MAX_FILE_SIZE_BYTES=26214400
OPENCANVAS_DOCUMENT_CHUNK_SIZE_CHARS=2000
OPENCANVAS_DOCUMENT_CHUNK_OVERLAP_CHARS=300
OPENCANVAS_DOCUMENT_MAX_PDF_PAGES=500
OPENCANVAS_DOCUMENT_MAX_EXTRACTED_CHARACTERS=5000000
OPENCANVAS_DOCUMENT_DOCX_MAX_MEMBERS=2000
OPENCANVAS_DOCUMENT_DOCX_MAX_UNCOMPRESSED_BYTES=104857600
OPENCANVAS_DOCUMENT_RETRIEVAL_TOP_K=8
OPENCANVAS_DOCUMENT_RELEVANCE_THRESHOLD=0.2
# `auto` sends extracted chunks to OpenAI for embeddings when OPENAI_API_KEY is set.
# Set `mock` for fully local deterministic embeddings.
OPENCANVAS_EMBEDDING_PROVIDER=auto
OPENCANVAS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENCANVAS_EMBEDDING_DIMENSIONS=1536
OPENCANVAS_EMBEDDING_BATCH_SIZE=64

# Web (required by the browser build when the API is not at the local default).
# Only browser-safe values may use NEXT_PUBLIC_; never expose credentials here.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
