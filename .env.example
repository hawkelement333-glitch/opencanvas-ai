# SolarPlexus Mobius configuration template — placeholders and safe local defaults only.
# Copy to .env for local development. Never commit .env or real credentials.

# Runtime identity: demo | development | test | staging | production
# Demo must be started with `pnpm demo`; do not hand-build demo settings from this file.
APP_MODE=development
OPENCANVAS_APP_URL=http://localhost:3000
OPENCANVAS_API_PREFIX=/api/v1
OPENCANVAS_CORS_ORIGINS=["http://localhost:3000"]

# Database
OPENCANVAS_DATABASE_URL=postgresql+asyncpg://opencanvas:opencanvas@localhost:5432/opencanvas
OPENCANVAS_DATABASE_POOL_SIZE=10
OPENCANVAS_DATABASE_POOL_TIMEOUT_SECONDS=15

# Authentication and sessions
OPENCANVAS_AUTH_ENABLED=true
OPENCANVAS_AUTH_TEST_BYPASS=false
# Replace in every shared/deployed environment with at least 32 random bytes.
OPENCANVAS_SESSION_SECRET=development-only-session-secret-change-before-deploying
OPENCANVAS_SESSION_COOKIE_NAME=mobius_session
OPENCANVAS_SESSION_TTL_MINUTES=10080
OPENCANVAS_SESSION_SAME_SITE=lax
OPENCANVAS_CSRF_HEADER_NAME=X-CSRF-Token
OPENCANVAS_PASSWORD_RESET_TTL_MINUTES=30
# development_token is local-only. Staging/production require smtp.
OPENCANVAS_PASSWORD_RESET_PROVIDER=development_token
OPENCANVAS_SMTP_HOST=
OPENCANVAS_SMTP_PORT=587
OPENCANVAS_SMTP_USERNAME=
OPENCANVAS_SMTP_PASSWORD=
OPENCANVAS_SMTP_FROM_ADDRESS=
OPENCANVAS_SMTP_STARTTLS=true

# AI and embeddings — provider selection is always explicit; there is no mock fallback.
OPENCANVAS_AI_PROVIDER=mock
OPENAI_API_KEY=
OPENCANVAS_OPENAI_MODEL=gpt-5.6-terra
OPENCANVAS_OPENAI_TIMEOUT_SECONDS=45
OPENCANVAS_AI_PROVIDER_CONFIGURATION_VERSION=openai-responses-v1
OPENCANVAS_AI_CONTEXT_CHARACTER_LIMIT=60000
OPENCANVAS_AI_MAX_OUTPUT_TOKENS=1600
OPENCANVAS_EMBEDDING_PROVIDER=mock
OPENCANVAS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENCANVAS_EMBEDDING_DIMENSIONS=1536
OPENCANVAS_EMBEDDING_BATCH_SIZE=64
OPENCANVAS_EMBEDDING_PROVIDER_CONFIGURATION_VERSION=openai-embeddings-v1

# Private file storage: local for development/test; s3 for staging/production.
OPENCANVAS_STORAGE_PROVIDER=local
OPENCANVAS_DOCUMENT_STORAGE_ROOT=./data/documents
OPENCANVAS_OBJECT_STORAGE_BUCKET=
OPENCANVAS_OBJECT_STORAGE_REGION=us-east-1
OPENCANVAS_OBJECT_STORAGE_ENDPOINT=
OPENCANVAS_OBJECT_STORAGE_ACCESS_KEY_ID=
OPENCANVAS_OBJECT_STORAGE_SECRET_ACCESS_KEY=
OPENCANVAS_OBJECT_STORAGE_PREFIX=mobius
OPENCANVAS_OBJECT_STORAGE_FORCE_PATH_STYLE=false

# Durable document jobs
OPENCANVAS_JOB_PROVIDER=database
OPENCANVAS_WORKER_POLL_INTERVAL_SECONDS=1
OPENCANVAS_WORKER_HEARTBEAT_SECONDS=15
OPENCANVAS_WORKER_STALE_AFTER_SECONDS=120
OPENCANVAS_PROCESSING_RETRY_LIMIT=3
OPENCANVAS_PROCESSING_RETRY_BASE_SECONDS=5
OPENCANVAS_PROCESSING_MAX_CONCURRENT_PER_WORKSPACE=3

# Upload, extraction, retrieval, request, and abuse limits
OPENCANVAS_DOCUMENT_MAX_FILE_SIZE_BYTES=26214400
OPENCANVAS_DOCUMENT_MAX_FILES_PER_REQUEST=10
OPENCANVAS_DOCUMENT_CHUNK_SIZE_CHARS=2000
OPENCANVAS_DOCUMENT_CHUNK_OVERLAP_CHARS=300
OPENCANVAS_DOCUMENT_MAX_PDF_PAGES=500
OPENCANVAS_DOCUMENT_MAX_EXTRACTED_CHARACTERS=5000000
OPENCANVAS_DOCUMENT_DOCX_MAX_MEMBERS=2000
OPENCANVAS_DOCUMENT_DOCX_MAX_UNCOMPRESSED_BYTES=104857600
OPENCANVAS_DOCUMENT_RETRIEVAL_TOP_K=8
OPENCANVAS_DOCUMENT_RELEVANCE_THRESHOLD=0.2
OPENCANVAS_REQUEST_MAX_BODY_BYTES=31457280
OPENCANVAS_QUESTION_MAX_CHARACTERS=8000
OPENCANVAS_REQUESTS_PER_USER_PER_MINUTE=120
OPENCANVAS_REQUESTS_PER_WORKSPACE_PER_MINUTE=300
OPENCANVAS_AI_REQUESTS_PER_USER_PER_MINUTE=20
OPENCANVAS_AUTH_REQUESTS_PER_IP_PER_MINUTE=10
OPENCANVAS_MONTHLY_TOKEN_BUDGET_PER_WORKSPACE=2000000
OPENCANVAS_ESTIMATED_INPUT_COST_PER_MILLION_TOKENS=0
OPENCANVAS_ESTIMATED_OUTPUT_COST_PER_MILLION_TOKENS=0

# Observability
OPENCANVAS_LOG_LEVEL=INFO
OPENCANVAS_LOG_JSON=true
OPENCANVAS_ERROR_TRACKING_DSN=
OPENCANVAS_TELEMETRY_ENABLED=false
OPENCANVAS_TELEMETRY_ENDPOINT=
OPENCANVAS_CORRELATION_HEADER_NAME=X-Request-ID

# Browser-safe build setting. Never put a secret in NEXT_PUBLIC_*.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CSRF_COOKIE_NAME=mobius_session_csrf
